---
import Layout from "../layouts/Layout.astro";
import App from "../components/App.jsx";

// prerender = false agar Astro tidak mencoba static-generate route ini.
// Semua URL yang tidak dikenal Astro akan ditangkap di sini,
// lalu diteruskan ke React Router (BrowserRouter) di client.
export const prerender = false;
---

<Layout>
  <App client:only="react" />
</Layout>
